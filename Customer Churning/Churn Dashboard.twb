      <aliases enabled='yes' />
      <column caption='Actual Churn Count' datatype='integer' datatype-customized='true' name='[Calculation_942096762065321987]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Churn]' />
      </column>
      <column caption='Overall Churn Rate' datatype='real' default-format='p0.00%' name='[Calculation_942096762069692420]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Churn]) / COUNT([gender])' />
      </column>
      <column caption='Revenue at Risk' datatype='real' default-format='c&quot;$&quot;#,##0.00' name='[Calculation_942096762070020101]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Predicted_Churn_XGB] = 1 THEN [MonthlyCharges] ELSE 0 END' />
      </column>
      <column caption='Total Revenue at Risk' datatype='real' name='[Calculation_942096762070319110]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_942096762070020101])' />
      </column>
      <column caption='Lost Revenue (FN)' datatype='real' default-format='c&quot;$&quot;#,##0.00' name='[Calculation_942096762070433799]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Churn] = 1 AND [Predicted_Churn_XGB] = 0 THEN [MonthlyCharges] ELSE 0 END' />
      </column>
      <column caption='Wasted Budget (FP)' datatype='real' default-format='c&quot;$&quot;#,##0.00' name='[Calculation_942096762070671368]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Churn] = 0 AND [Predicted_Churn_XGB] = 1 THEN [MonthlyCharges] ELSE 0 END' />
      </column>
      <column caption='ROC AUC Value' datatype='real' default-format='n0.0000' name='[Calculation_942096762120839178]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0.8500' />
      </column>
      <column caption='Churn Status Label' datatype='string' name='[Calculation_942096762123845643]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Churn] = 1 THEN &quot;Churned&quot; ELSE &quot;Retained&quot; END' />
      </column>
      <column caption='churn rate' datatype='real' default-format='p0.00%' name='[Calculation_942096762130849805]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Churn]) / SUM([Churn]) + SUM(1 - [Churn])' />
      </column>
      <column caption='Total Actionable Revenue' datatype='real' default-format='c&quot;$&quot;#,##0.00' name='[Calculation_942096762145333265]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_942096762070433799] + [Calculation_942096762070671368]' />
      </column>
      <column aggregation='Count' datatype='integer' datatype-customized='true' name='[Churn]' role='measure' type='quantitative' />
      <column caption='Device Protection' datatype='string' name='[DeviceProtection]' role='dimension' type='nominal' />
      <column caption='Gender' datatype='string' name='[Gender (copy)_942096762135580688]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[gender]' />
      </column>
      <column caption='Internet Service' datatype='string' name='[InternetService]' role='dimension' type='nominal' />
      <column aggregation='None' caption='Monthly Charges (bin)' datatype='integer' name='[Monthly Charges (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='1' formula='[MonthlyCharges]' peg='0' size='10' />
      </column>
      <column caption='Monthly Charges' datatype='real' name='[MonthlyCharges]' role='measure' type='quantitative' />
