# --- Database Credentials ---
# These are used by the Postgres container to initialize the databases
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB_METADATA=airflow_metadata
POSTGRES_DB_WAREHOUSE=ecommerce_data

# --- Airflow Infrastructure ---
# AIRFLOW_UID ensures file permission sync between your host machine and the container
AIRFLOW_UID=50000
FERNET_KEY=gJ8L0CldxDkfuAP2a5xfK8j5s8HrqDCFujXPtpAcRig=
SECRET_KEY=qusyF81y2iOXlstOGjkC2wJc/EYdXTkP8Ug1mIMYjis=
# --- Internal Docker Connection Strings ---
# Airflow uses these to talk to the Postgres services internally via the 'postgres' hostname
AIRFLOW_METADATA_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB_METADATA}
AIRFLOW_WAREHOUSE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB_WAREHOUSE}